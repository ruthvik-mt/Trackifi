# Root .env.example for Docker Compose
# Copy this file to .env and fill in your values

# Database (Aiven PostgreSQL or local Docker)
DB_URL=jdbc:postgresql://your-host.aivencloud.com:port/defaultdb?sslmode=require
DB_USERNAME=avnadmin
DB_PASSWORD=your_database_password

# Authentication (JWT)
JWT_SECRET=your_secure_jwt_secret_here_make_sure_it_is_long_enough
JWT_ACCESS_TOKEN_EXPIRATION=1d
JWT_REFRESH_TOKEN_EXPIRATION=7d

# Email (Gmail SMTP)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_app_password

# Frontend URL (for CORS and email verification links)
FRONTEND_URL=http://localhost:5173
