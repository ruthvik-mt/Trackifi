# .env.example for Trackifi Backend
# Copy this file to .env and fill in your values

# Database (Aiven PostgreSQL or local Docker)
DB_URL=jdbc:postgresql://your-host.aivencloud.com:port/defaultdb?sslmode=require
DB_USERNAME=avnadmin
DB_PASSWORD=your_database_password

# Authentication (JWT)
JWT_SECRET=your_secure_jwt_secret_here_make_sure_it_is_long_enough
JWT_ACCESS_TOKEN_EXPIRATION=1d
JWT_REFRESH_TOKEN_EXPIRATION=7d

# Email (Brevo SMTP)
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=2525
MAIL_USERNAME=your_brevo_login@smtp-brevo.com
MAIL_PASSWORD=your_brevo_smtp_key
MAIL_FROM=trackifii@gmail.com

# URLs
FRONTEND_URL=http://localhost:5173